@* Shows available prompt placeholders and their descriptions *@

<div class="rounded-lg border border-slate-200 dark:border-slate-600 overflow-hidden">
    <div class="px-3 py-2 bg-slate-100 dark:bg-slate-700 border-b border-slate-200 dark:border-slate-600">
        <span class="text-xs font-semibold text-slate-600 dark:text-slate-200 uppercase tracking-wide">Available Placeholders</span>
    </div>
    <table class="w-full text-xs">
        <tbody>
            @foreach (var p in Placeholders)
            {
                <tr class="border-b border-slate-100 dark:border-slate-700 last:border-0 dark:bg-slate-800">
                    <td class="px-3 py-2 w-56 font-mono text-blue-700 dark:text-blue-400 whitespace-nowrap">@p.Token</td>
                    <td class="px-3 py-2 text-slate-600 dark:text-slate-300">@p.Description</td>
                </tr>
            }
        </tbody>
    </table>
</div>

@code {
    [Parameter, EditorRequired] public IEnumerable<(string Token, string Description)> Placeholders { get; set; } = [];
}
